{
    "dataset": {
        "dataset_dir": "dataset",
        "image_dir": "images",
        "label_path": "labels.csv",
        "test_size": 0.2,
        "random_state": 42,
        "shuffle": true
    },
    "output": {
        "output_dir": "output",
        "processed_dir": "processed",
        "errorlog_dir": "errorlog"
    },
    "preprocesser": {
        "save_processed": true,
        "auto_rotate": false,
        "resize_scale": 2,
        "contrast_factor": 2.0,
        "median_filter_size": 3,
        "background_blur_radius": 25,
        "modes": {
            "raw": {
                "enable": true,
                "threshold": 0
            },
            "gray": {
                "enable": true,
                "threshold": 0
            },
            "contrast": {
                "enable": true,
                "threshold": 0
            },
            "binary": {
                "enable": true,
                "thresholds": [
                    100,
                    120,
                    140,
                    150,
                    160,
                    180,
                    200
                ]
            },
            "background": {
                "enable": true,
                "thresholds": [
                    100,
                    120,
                    140,
                    150,
                    160,
                    180,
                    200
                ]
            }
        }
    }
}